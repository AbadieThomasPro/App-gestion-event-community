# URL de connexion locale (hors Docker)
# En Docker, utiliser db comme hostname (voir docker-compose.yml)
DATABASE_URL="postgresql://dev:dev@localhost:5432/app_events"
DATABASE_URL_UNPOOLED="postgresql://dev:dev@localhost:5432/app_events"

# Secret utilisé pour signer/vérifier les JWT (local uniquement)
JWT_SECRET="local-dev-secret-change-me"

# Origine autorisée par CORS pour les requêtes du frontend
FRONTEND_URL="http://localhost:4200"
